DATABASE_URL=postgresql+psycopg://codeintel:codeintel@localhost:5434/codeintel
APP_ENV=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WORKER_ID=worker-local
JOB_LEASE_SECONDS=60
JOB_RETRY_DELAY_SECONDS=30
WORKER_POLL_INTERVAL_SECONDS=2
GIT_CLONE_TIMEOUT_SECONDS=120
GIT_CLONE_MAX_BYTES=52428800
GIT_CLONE_BASE_DIR=/tmp/codeintel-clones

# Optional LLM enrichment. Leave disabled for deterministic indexing / CI.
# Primary provider when enabled: azure_openai (see docs/llm-enrichment.md).
LLM_ENRICHMENT_ENABLED=false
LLM_PROVIDER=none
LLM_MODEL=
LLM_API_KEY=
LLM_API_BASE=
LLM_TEMPERATURE=0
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2
LLM_PROMPT_VERSION=1
LLM_MAX_REQUESTS_PER_JOB=50
LLM_MAX_TOKENS_PER_FILE=4000
LLM_MAX_TOKENS_PER_REPOSITORY=100000
LLM_MAX_TOKENS_PER_JOB=80000
LLM_MAX_ESTIMATED_COST_USD_PER_JOB=0.50
LLM_DAILY_BUDGET_USD=5.0
LLM_KILL_SWITCH=false
LLM_MAX_CHUNKS_PER_REQUEST=12
LLM_ORCHESTRATION=auto

# Azure OpenAI (required when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# Embeddings (Week 9). CI/default uses local-hash; Azure for live semantic quality.
# EMBEDDINGS_ENABLED=true
# EMBEDDING_PROVIDER=local
# EMBEDDING_MODEL=local-hash-v1
# EMBEDDING_VERSION=9.2
EMBEDDING_DIMENSIONS=1536

# Week 10 Ask/RAG (Days 1–4). Search stays deterministic; Ask uses these budgets.
# ASK_CANDIDATE_EXACT_LIMIT=30
# ASK_CANDIDATE_SEMANTIC_LIMIT=30
# ASK_RRF_K=60
# ASK_RERANK_ENABLED=true
# ASK_RERANK_MAX_CANDIDATES=40
# ASK_RERANK_USE_MOCK=true
# ASK_QUERY_REWRITE_ENABLED=true
# ASK_QUERY_MAX_REWRITES=4
# ASK_CONTEXT_TOKEN_BUDGET=6000
# ASK_EXPAND_SEED_LIMIT=5
# ASK_EXPAND_NEIGHBOR_LIMIT=2
# ASK_EXPAND_RELATION_LIMIT=4
# ASK_EXPAND_LOW_CONFIDENCE_SCORE=0.02

# Live Azure embedding smoke (opt-in; never run in CI):
#   RUN_AZURE_INTEGRATION_TESTS=true .venv/bin/python scripts/test_azure_embedding.py
